# Same as ../.env.example — kept here for deploy/Railway config-dir conventions.
# Copy to `.env` in the service root for local `go run`.

ENVIRONMENT=development
SERVICE_NAME=warehouse
PORT=4005
LOG_LEVEL=info

DATABASE_URL=postgres://svc_iag_warehouse:iag_warehouse_dev@localhost:5432/iag_platform?sslmode=disable
AUTO_MIGRATE=true

AUTH_MODE=jwt
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json
AUDIENCE=iag.warehouse
GATEWAY_API_PREFIX=/api/v1/warehouse
PUBLIC_API_URL=http://localhost:8080

SERVICE_CLIENT_ID=iag-warehouse
SERVICE_CLIENT_SECRET=

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

EVENT_BUS_ENABLED=true
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=iag-warehouse
KAFKA_CONSUMER_GROUP=iag.warehouse
KAFKA_OPERATIONS_TOPIC=iag.operations
KAFKA_COMMERCIAL_TOPIC=iag.commercial
KAFKA_PRODUCTION_TOPIC=iag.production
KAFKA_QUALITY_TOPIC=iag.quality
KAFKA_SUPPLY_CHAIN_TOPIC=iag.supply-chain
