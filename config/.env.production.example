# Production — copy to Railway / host env. Never commit secrets.

ENVIRONMENT=production
SERVICE_NAME=warehouse
PORT=4005
LOG_LEVEL=info
AUTH_MODE=jwt

AUDIENCE=iag.warehouse
JWT_ISSUER=https://auth.example.com
JWKS_URL=https://auth.example.com/.well-known/jwks.json
GATEWAY_API_PREFIX=/api/v1/warehouse
PUBLIC_API_URL=https://api.example.com

SERVICE_CLIENT_ID=iag-warehouse
SERVICE_CLIENT_SECRET=
AUTH_TOKEN_URL=https://auth.example.com/oauth/token

# Least-privilege the service-callable endpoints (items, issues, spare-parts,
# production consume/output) to known peers. Empty would trust any service.
WAREHOUSE_SERVICE_CALLERS=iag-fleet,iag-mes

DATABASE_URL=postgres://svc_iag_warehouse:CHANGE_ME@pgbouncer:6432/iag_platform?sslmode=require
AUTO_MIGRATE=false

EVENT_BUS_ENABLED=true
KAFKA_BROKERS=redpanda:9092
KAFKA_CONSUMER_GROUP=iag.warehouse
KAFKA_OPERATIONS_TOPIC=iag.operations
KAFKA_COMMERCIAL_TOPIC=iag.commercial
KAFKA_PRODUCTION_TOPIC=iag.production
KAFKA_QUALITY_TOPIC=iag.quality
KAFKA_SUPPLY_CHAIN_TOPIC=iag.supply-chain
KAFKA_CLIENT_ID=iag-warehouse

# Comma-separated browser origins (no wildcards in production)
ALLOWED_ORIGINS=https://app.example.com
