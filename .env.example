# Local development — see config/.env.production.example for production.
# Copy to `.env` in this directory.

ENVIRONMENT=development
SERVICE_NAME=warehouse
PORT=4005
LOG_LEVEL=info

# ─── Postgres (schema: warehouse) ─────────────────────────────────────────
DATABASE_URL=postgres://svc_iag_warehouse:iag_warehouse_dev@localhost:5432/iag_platform?sslmode=disable
AUTO_MIGRATE=true

# ─── Platform JWT (Bearer + aud=iag.warehouse) ───────────────────────────
AUTH_MODE=jwt
JWT_ISSUER=http://localhost:3001
JWKS_URL=http://127.0.0.1:3001/.well-known/jwks.json
AUDIENCE=iag.warehouse
GATEWAY_API_PREFIX=/api/v1/warehouse
PUBLIC_API_URL=http://localhost:8080
# AUTH_TOKEN_URL defaults to JWT_ISSUER + /oauth/token when unset

# Service account — registers warehouse.* permissions with iag-authentication.
SERVICE_CLIENT_ID=iag-warehouse
SERVICE_CLIENT_SECRET=

# Peer services allowed on the service-callable endpoints (items, issues,
# spare-parts, production consume/output). Comma-separated client ids.
# Empty = trust any authenticated service principal (still gated by JWT + aud).
# Set this in shared/staging/prod to least-privilege the surface.
WAREHOUSE_SERVICE_CALLERS=iag-fleet,iag-mes

# Browser CORS (comma-separated). Aliases: CORS_ORIGIN, ALLOWED_ORIGINS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Kafka / outbox (publishes to iag.operations; consumes cross-domain) ───
EVENT_BUS_ENABLED=true
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=iag-warehouse
KAFKA_CONSUMER_GROUP=iag.warehouse
KAFKA_OPERATIONS_TOPIC=iag.operations
KAFKA_COMMERCIAL_TOPIC=iag.commercial
KAFKA_PRODUCTION_TOPIC=iag.production
KAFKA_QUALITY_TOPIC=iag.quality
KAFKA_SUPPLY_CHAIN_TOPIC=iag.supply-chain
